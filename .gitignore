# Squad: ignore runtime state (logs, inbox, sessions)
.squad/orchestration-log/
.squad/log/
.squad/decisions/inbox/
.squad/sessions/
# Squad: SubSquad activation file (local to this machine)
.squad-workstream

# Squad archives
.squad-archive*/

# Cloned companion-module-*/ review checkouts are NOT listed here so that
# Copilot can @-reference them. Accidental commits are blocked by the
# pre-commit hook in .githooks/. Run `git config core.hooksPath .githooks`
# once after cloning (or run setup.ps1) to activate the hook.
