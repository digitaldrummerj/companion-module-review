# Squad: ignore runtime state (logs, inbox, sessions)
.squad/orchestration-log/
.squad/log/
.squad/decisions/inbox/
.squad/sessions/
# Squad: SubSquad activation file (local to this machine)
.squad-workstream

# Squad archives
.squad-archive*/

# Companion module checkouts belong in the companion-modules-reviewing/ sibling directory,
# NOT inside this repo. This entry is a safety net in case one is accidentally cloned here.
# The pre-commit hook in .githooks/ provides a second layer of protection.
companion-module-*/

