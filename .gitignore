# Squad: ignore runtime state (logs, inbox, sessions)
.squad/orchestration-log/
.squad/log/
.squad/decisions/inbox/
.squad/sessions/
# Squad: SubSquad activation file (local to this machine)
.squad-workstream

# Squad archives
.squad-archive*/

# Note: companion-module-*/ is excluded via .git/info/exclude (local only)
# This allows Copilot to @-reference cloned modules while still excluding
# them from git commits.
