#!/bin/sh
# Prevent accidental commits of cloned module checkouts. These live under
# companion-modules-reviewing/ inside the repo (or at the root by mistake) and
# are local review checkouts that should never be committed.

BLOCKED=$(git diff --cached --name-only | grep -E '^(companion-modules-reviewing/|companion-module-[^/]+/)')

if [ -n "$BLOCKED" ]; then
    echo ""
    echo "ERROR: Staged files are inside a companion-module-* directory:"
    echo "$BLOCKED" | sed 's/^/  /'
    echo ""
    echo "Cloned module directories are local review checkouts — do not commit them."
    echo "Run: git reset HEAD <file> to unstage."
    echo ""
    exit 1
fi
